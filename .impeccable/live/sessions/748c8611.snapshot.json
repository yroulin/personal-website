      "outerHTML": "<section class=\"section\" aria-labelledby=\"projects-heading\"><div style=\"opacity: 1; transform: none;\"><p class=\"section-marker\" aria-hidden=\"true\">04</p><h2 id=\"projects-heading\" class=\"section-heading\">Featured Projects</h2></div><ol class=\"projects-list\" aria-label=\"Featured Projects\"><li class=\"project-row\" style=\"opacity: 1; transform: none;\"><span class=\"project-num\" aria-hidden=\"true\">01</span><div><h3 class=\"project-title\">AEM Core Components Extension</h3><p class=\"project-desc\">A comprehensive library of custom AEM components designed for high-traffic corporate environments, focusing on performance and accessibility.</p><div class=\"project-tags\" aria-label=\"Technologies used\"><span class=\"project-tag\">AEM</span><span class=\"project-tag\">Java</span><span class=\"project-tag\">HTL</span><span class=\"project-tag\">SCSS</span></div></div></li><li class=\"project-row\" style=\"opacity: 1; transform: none;\"><span class=\"project-num\" aria-hidden=\"true\">02</span><div><h3 class=\"project-title\">Lightning Tip Dashboard</h3><p class=\"project-desc\">A decentralized payment dashboard that allows creators to receive Bitcoin Lightning tips directly, featuring real-time QR code generation.</p><div class=\"project-tags\" aria-label=\"Technologies used\"><span class=\"project-tag\">Next.js</span><span class=\"project-tag\">LNURL</span><span class=\"project-tag\">Tailwind</span></div></div></li><li class=\"project-row\" style=\"opacity: 0; transform: translateY(16px);\"><span class=\"project-num\" aria-hidden=\"true\">03</span><div><h3 class=\"project-title\">Personal Portfolio v2</h3><p class=\"project-desc\">A high-performance portfolio featuring smooth parallax effects, glassmorphism UI, and dark mode support, built with modern web standards.</p><div class=\"project-tags\" aria-label=\"Technologies used\"><span class=\"project-tag\">React</span><span class=\"project-tag\">Framer Motion</span><span class=\"project-tag\">Shadcn</span></div></div></li></ol></section>",
